# ==========================================
# Global Configuration
# ==========================================
# Replace with your actual domain and email for Let's Encrypt
DOMAIN=ktown.gg
ACME_EMAIL=admin@ktown.gg
TZ=Europe/Oslo

# ==========================================
# Database Core (Stack 04 & pgAdmin)
# ==========================================
POSTGRES_USER=admin
POSTGRES_PASSWORD=replace_with_secure_db_password

# ==========================================
# Authentik (Stack 02)
# ==========================================
AUTHENTIK_POSTGRES_DB=authentik
AUTHENTIK_POSTGRES_USER=authentik_user
AUTHENTIK_POSTGRES_PASSWORD=replace_with_secure_authentik_db_password

# The secret key is crucial for Authentik's security.
# Generate one using: openssl rand -base64 36
AUTHENTIK_SECRET_KEY=replace_with_generated_secret_key
